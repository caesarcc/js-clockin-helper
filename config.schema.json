{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Configuração da Calculadora de Jornada",
  "type": "object",
  "properties": {
    "entrada": { "type": "string", "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$" },
    "saida_almoco": { "type": "string", "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$" },
    "retorno_almoco": { "type": "string", "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$" },
    "carga_diaria": { "type": "string", "pattern": "^([0-1]\\d|2[0-3]):([0-5]\\d)$" },
    "tema": { "type": "string", "enum": ["light", "dark", "auto"] }
  },
  "required": ["entrada", "saida_almoco", "retorno_almoco", "carga_diaria"],
  "additionalProperties": false
}
